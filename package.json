{
  "name": "eurobasqet",
  "version": "0.1.0",
  "private": true,
  "description": "Eurobasqet — a web/mobile-first basketball GM simulation built around a European league pyramid with promotion/relegation and developmental teams.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace @eurobasqet/mobile",
    "web": "npm run web --workspace @eurobasqet/mobile",
    "android": "npm run android --workspace @eurobasqet/mobile",
    "ios": "npm run ios --workspace @eurobasqet/mobile",
    "typecheck": "tsc -b packages/data packages/engine",
    "sim:demo": "npm run demo --workspace @eurobasqet/engine",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.22.5"
  }
}
