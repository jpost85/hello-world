# ─── Server ───────────────────────────────────────────────────────────────
PORT=3000
# How often (in seconds) to check each watched sheet for changes.
POLL_INTERVAL_SECONDS=30

# ─── Google Drive access ────────────────────────────────────────────────────
# Path to a Google service-account JSON key file. The service account must be
# granted at least Viewer access to every sheet you want to watch (share the
# sheet with the service account's client_email).
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# Alternative to the file path above: paste the entire service-account JSON
# as a single-line string. Useful on hosts where you set env vars but can't
# upload files. If set, this takes precedence over the file path.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# ─── Notifications: Twilio SMS (primary) ────────────────────────────────────
# Leave blank to disable SMS. Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The Twilio phone number to send FROM, in E.164 format, e.g. +15551234567
TWILIO_FROM_NUMBER=
# Optional: a default recipient to seed the list on first run. After that,
# manage recipient phone numbers in the web UI. E.164 format, e.g. +15557654321
NOTIFY_SMS_TO=

# ─── Notifications: Email (fallback) ────────────────────────────────────────
# Leave SMTP_HOST blank to disable email. For Gmail use an App Password.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
# Optional: a default email recipient to seed the list on first run. After
# that, manage email recipients in the web UI.
NOTIFY_EMAIL_TO=
